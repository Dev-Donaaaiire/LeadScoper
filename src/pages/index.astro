---
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>LeadScoper - Automatiza tu Prospección</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap"
			rel="stylesheet"
		/>
		<style>
			body {
				font-family: "Inter", sans-serif;
			}

			.neon-shadow {
				box-shadow: 0 0 15px rgba(34, 197, 94, 0.5);
			}

			.neon-text {
				text-shadow: 0 0 10px rgba(34, 197, 94, 0.7);
			}

			.cyber-grid {
				background-image:
					linear-gradient(
						rgba(0, 255, 136, 0.05) 1px,
						transparent 1px
					),
					linear-gradient(
						90deg,
						rgba(0, 255, 136, 0.05) 1px,
						transparent 1px
					);
				background-size: 30px 30px;
			}

			/* Custom Scrollbar */
			::-webkit-scrollbar {
				width: 8px;
				height: 8px;
			}

			::-webkit-scrollbar-track {
				background: #0a0a0a;
			}

			::-webkit-scrollbar-thumb {
				background: #333;
				border-radius: 4px;
			}

			::-webkit-scrollbar-thumb:hover {
				background: #22c55e;
			}

			/* Animations */
			.fade-in-up {
				opacity: 0;
				transform: translateY(20px);
				transition:
					opacity 0.6s ease-out,
					transform 0.6s ease-out;
			}

			.fade-in-up.visible {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>

	<body class="bg-brand-black text-gray-200 antialiased overflow-x-hidden">
		<!-- Navbar -->
		<nav
			class="fixed w-full z-50 bg-brand-black/90 backdrop-blur border-b border-brand-gray/50"
		>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex items-center justify-between h-16">
					<div class="flex items-center gap-2">
						<span
							class="text-2xl font-black tracking-tighter text-white"
							>LeadScoper</span
						>
					</div>
					<div class="hidden md:block">
						<a
							href="#oferta"
							class="bg-brand-green/10 text-brand-green border border-brand-green/50 px-4 py-2 rounded font-bold hover:bg-brand-green hover:text-black transition duration-300"
						>
							Acceso Beta
						</a>
					</div>
				</div>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="relative pt-24 pb-16 lg:pt-48 lg:pb-32 cyber-grid">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<div
					class="inline-block px-4 py-1.5 mb-6 rounded-full border border-brand-green/30 bg-brand-green/5 text-brand-green text-sm font-semibold tracking-wide animate-pulse"
				>
					🚀 Novedad: Deep Search + Backend Detector
				</div>
				<h1
					class="text-3xl sm:text-5xl md:text-7xl font-black text-white leading-tight mb-6"
				>
					Deja de buscar clientes en <br class="hidden md:block" />
					<span
						class="bg-clip-text text-transparent bg-gradient-to-r from-brand-green to-brand-cyan"
						>Google Maps manualmente.</span
					>
				</h1>
				<p class="mt-4 max-w-2xl mx-auto text-xl text-gray-400 mb-10">
					El primer Bot que no solo scrapea: <span
						class="text-white font-semibold"
						>analiza la tecnología (Wix/WP)</span
					> para que vendas migraciones con datos reales de tus prospectos
					de Google Maps.
				</p>

				<div
					class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-16"
				>
					<a
						href="#oferta"
						class="px-8 py-4 bg-brand-green text-black font-black text-lg rounded shadow-[0_0_20px_rgba(34,197,94,0.6)] hover:shadow-[0_0_30px_rgba(34,197,94,0.8)] hover:-translate-y-1 transition duration-300 w-full sm:w-auto flex flex-col items-center"
					>
						<span>CONSEGUIR ACCESO BETA</span>
						<span class="text-sm font-normal opacity-90"
							>Planes desde 10,99€/mes</span
						>
					</a>
					<div class="flex flex-col text-left">
						<span class="text-white font-bold text-lg"
							>🔥 Planes Flexibles</span
						>
						<span class="text-gray-400 text-sm"
							>Desde 1 Mes hasta Lifetime.</span
						>
					</div>
				</div>

				<!-- Terminal Demo Placeholder (Now Video) -->
				<div
					class="relative max-w-4xl mx-auto rounded-lg overflow-hidden border border-brand-gray bg-brand-dark shadow-2xl transform skew-y-0 md:skew-y-1 hover:skew-y-0 transition duration-700 w-full mb-8 md:mb-0"
				>
					<div
						class="flex items-center gap-2 px-4 py-2 bg-gray-800 border-b border-gray-700"
					>
						<div class="w-3 h-3 rounded-full bg-red-500"></div>
						<div class="w-3 h-3 rounded-full bg-yellow-500"></div>
						<div class="w-3 h-3 rounded-full bg-green-500"></div>
						<span class="ml-2 text-xs text-gray-400 font-mono"
							>leadscoper_demo_preview.yt</span
						>
					</div>
					<div class="bg-black relative aspect-video">
						<iframe
							class="w-full h-full"
							src="https://www.youtube.com/embed/ajidPpAwwlM?autoplay=0&rel=0&controls=1&showinfo=0&modestbranding=1"
							title="LeadScoper Demo"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
						>
						</iframe>
					</div>
				</div>
			</div>
		</section>

		<!-- Agitation Section -->
		<section class="py-20 bg-brand-dark border-t border-brand-gray/30">
			<div class="max-w-5xl mx-auto px-4 text-center">
				<h2 class="text-3xl md:text-4xl font-bold text-white mb-12">
					¿Cuánto dinero pierdes haciendo esto a mano?
				</h2>
				<div class="grid md:grid-cols-3 gap-8">
					<!-- Pain 1 -->
					<div
						class="p-6 bg-brand-gray/20 rounded-xl border border-red-500/20 hover:border-red-500/50 transition duration-300"
					>
						<div class="text-5xl mb-4">😫</div>
						<h3 class="text-xl font-bold text-white mb-2">
							4 Horas Perdidas
						</h3>
						<p class="text-gray-400">
							Copiando y pegando teléfonos a un Excel. Tiempo que
							podrías dedicar a programar o diseñar.
						</p>
					</div>
					<!-- Pain 2 -->
					<div
						class="p-6 bg-brand-gray/20 rounded-xl border border-red-500/20 hover:border-red-500/50 transition duration-300"
					>
						<div class="text-5xl mb-4">👻</div>
						<h3 class="text-xl font-bold text-white mb-2">
							Ghosting Infinito
						</h3>
						<p class="text-gray-400">
							Tus mensajes son ignorados porque suenan genéricos.
							No sabes qué tecnología usan.
						</p>
					</div>
					<!-- Pain 3 -->
					<div
						class="p-6 bg-brand-gray/20 rounded-xl border border-red-500/20 hover:border-red-500/50 transition duration-300"
					>
						<div class="text-5xl mb-4">🔍</div>
						<h3 class="text-xl font-bold text-white mb-2">
							Falta de Datos
						</h3>
						<p class="text-gray-400">
							Contactas empresas sin saber si su web está obsoleta
							o si necesitan tus servicios urgemente, mejor, sin
							ni siquiera ver tu mismo su web.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Solution/Features -->
		<section class="py-24 bg-brand-black relative overflow-hidden">
			<!-- Glow effects -->
			<div
				class="absolute top-1/4 left-0 w-64 h-64 bg-brand-green/10 rounded-full blur-[100px]"
			>
			</div>
			<div
				class="absolute bottom-1/4 right-0 w-64 h-64 bg-brand-cyan/10 rounded-full blur-[100px]"
			>
			</div>

			<div class="max-w-6xl mx-auto px-4">
				<div class="mb-16 text-center">
					<span
						class="text-brand-cyan font-bold tracking-wider uppercase text-sm"
						>La Solución Definitiva</span
					>
					<h2 class="text-4xl md:text-5xl font-bold text-white mt-2">
						Domina tu nicho automáticamente
					</h2>
				</div>

				<div class="grid md:grid-cols-2 gap-12 items-center">
					<div class="space-y-8">
						<div class="flex gap-4">
							<div
								class="w-12 h-12 rounded bg-brand-green/20 flex items-center justify-center text-brand-green text-2xl"
							>
								⚡
							</div>
							<div>
								<h3 class="text-xl font-bold text-white">
									Detector de Tecnología
								</h3>
								<p class="text-gray-400 mt-2">
									No vendas a ciegas. El bot entra en la web
									del cliente y te dice si usa <strong
										>Wix, WordPress o Shopify</strong
									>. Véndeles una migración con argumentos
									reales.
								</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div
								class="w-12 h-12 rounded bg-brand-cyan/20 flex items-center justify-center text-brand-cyan text-2xl"
							>
								📊
							</div>
							<div>
								<h3 class="text-xl font-bold text-white">
									Exportación Lista (CSV/Excel)
								</h3>
								<p class="text-gray-400 mt-2">
									Guarda todos los leads en un archivo
									ordenado con nombres, teléfonos, webs y su
									CMS. Listo para tu CRM o equipo de llamadas.
								</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div
								class="w-12 h-12 rounded bg-purple-500/20 flex items-center justify-center text-purple-400 text-2xl"
							>
								🛡️
							</div>
							<div>
								<h3 class="text-xl font-bold text-white">
									Filtrado Inteligente
								</h3>
								<p class="text-gray-400 mt-2">
									Dile al bot exactamente qué tipo de negocio
									buscas en Google Maps. Olvídate de limpiar
									listas interminables con datos basura.
								</p>
							</div>
						</div>
					</div>

					<!-- Visual Feature Representation -->
					<div
						class="bg-gray-900 border border-gray-700 rounded-2xl p-6 relative"
					>
						<div
							class="absolute -top-4 -right-4 bg-brand-green text-black font-bold px-4 py-1 rounded shadow-lg transform rotate-3"
						>
							Resultados
						</div>
						<div class="space-y-3 font-mono text-sm">
							<div
								class="flex justify-between items-center text-gray-400 border-b border-gray-800 pb-2"
							>
								<span>Target</span>
								<span>Resultados</span>
							</div>
							<div class="flex justify-between items-center">
								<span class="text-white">Restaurantes BCN</span>
								<span class="text-brand-green">108 Leads</span>
							</div>
							<div class="flex justify-between items-center">
								<span class="text-white">Gimnasios Madrid</span>
								<span class="text-brand-green">89 Leads</span>
							</div>
							<div class="flex justify-between items-center">
								<span class="text-white"
									>Inmobiliarias Val.</span
								>
								<span class="text-brand-green">215 Leads</span>
							</div>
							<div
								class="mt-4 pt-4 border-t border-gray-800 text-center"
							>
								<p class="text-xs text-gray-500">
									Tiempo empleado: 12 minutos
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- How it works -->
		<section class="py-20 bg-brand-dark">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-3xl md:text-4xl font-bold text-white mb-16">
					Es ridículamente fácil
				</h2>
				<div class="grid md:grid-cols-3 gap-8">
					<!-- Step 1 -->
					<div class="relative group">
						<div
							class="w-16 h-16 mx-auto bg-gray-800 rounded-full flex items-center justify-center text-2xl border border-gray-700 group-hover:border-brand-green transition mb-6 text-white font-bold"
						>
							1
						</div>
						<h3 class="text-xl font-bold text-white mb-4">
							Elige tu Objetivo
						</h3>
						<p class="text-sm text-gray-400">
							Define ciudad y nicho. Ej: "Abogados en Sevilla".
						</p>
					</div>
					<!-- Step 2 -->
					<div class="relative group">
						<div
							class="absolute top-8 left-0 w-full h-0.5 bg-gray-800 -z-10 hidden md:block"
						>
						</div>
						<div
							class="w-16 h-16 mx-auto bg-gray-800 rounded-full flex items-center justify-center text-2xl border border-gray-700 group-hover:border-brand-cyan transition mb-6 text-white font-bold"
						>
							2
						</div>
						<h3 class="text-xl font-bold text-white mb-4">
							El Bot Trabaja
						</h3>
						<p class="text-sm text-gray-400">
							Extrae datos, verifica tecnologías y filtra los
							prospectos mientras tú tomas café.
						</p>
					</div>
					<!-- Step 3 -->
					<div class="relative group">
						<div
							class="w-16 h-16 mx-auto bg-gray-800 rounded-full flex items-center justify-center text-2xl border border-gray-700 group-hover:border-brand-green transition mb-6 text-white font-bold"
						>
							3
						</div>
						<h3 class="text-xl font-bold text-white mb-4">
							Cierra Ventas
						</h3>
						<p class="text-sm text-gray-400">
							Exporta los datos a Excel y contacta sabiendo qué
							tecnología usan. Argumentos de venta irrefutables.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Comparison Section -->
		<section class="py-20 bg-brand-black relative">
			<div class="max-w-4xl mx-auto px-4">
				<h2
					class="text-3xl md:text-4xl font-bold text-white text-center mb-12"
				>
					No hay comparación
				</h2>
				<div class="overflow-x-auto">
					<table class="w-full text-left border-collapse">
						<thead>
							<tr>
								<th
									class="p-4 bg-gray-900/50 text-gray-400 font-medium rounded-tl-lg"
									>Características</th
								>
								<th
									class="p-4 bg-gray-900/50 text-gray-400 font-medium text-center"
									>Método Manual</th
								>
								<th
									class="p-4 bg-brand-green/20 text-brand-green font-bold text-center rounded-tr-lg border-t-2 border-brand-green"
								>
									LeadScoper</th
								>
							</tr>
						</thead>
						<tbody class="text-sm md:text-base">
							<tr class="border-b border-gray-800">
								<td class="p-2 md:p-4 text-white font-medium"
									>Velocidad</td
								>
								<td class="p-2 md:p-4 text-gray-500 text-center"
									>Lenta (1 a 1)</td
								>
								<td
									class="p-2 md:p-4 text-brand-green font-bold text-center bg-brand-green/5"
									>🚀 Ultra Rápida (Bulk)
								</td>
							</tr>
							<tr class="border-b border-gray-800">
								<td class="p-2 md:p-4 text-white font-medium"
									>Tecnología</td
								>
								<td class="p-2 md:p-4 text-gray-500 text-center"
									>Manual</td
								>
								<td
									class="p-2 md:p-4 text-brand-green font-bold text-center bg-brand-green/5"
									>Detección CMS (Wix/WP)
								</td>
							</tr>
							<tr class="border-b border-gray-800">
								<td class="p-2 md:p-4 text-white font-medium"
									>Calidad de Datos</td
								>
								<td class="p-2 md:p-4 text-gray-500 text-center"
									>Baja</td
								>
								<td
									class="p-2 md:p-4 text-brand-green font-bold text-center bg-brand-green/5"
									>Verificada
								</td>
							</tr>
							<tr>
								<td
									class="p-2 md:p-4 text-white font-medium rounded-bl-lg"
									>Costo</td
								>
								<td class="p-2 md:p-4 text-gray-500 text-center"
									>Tu tiempo (Valioso)</td
								>
								<td
									class="p-2 md:p-4 text-brand-green font-bold text-center bg-brand-green/5 rounded-br-lg"
								>
									Desde 10,99€/mes</td
								>
							</tr>
						</tbody>
					</table>
				</div>
			</div>
		</section>

		<!-- Pricing Section -->
		<section id="oferta" class="py-24 bg-brand-black relative">
			<div class="max-w-6xl mx-auto px-4">
				<h2
					class="text-3xl md:text-5xl font-bold text-white text-center mb-4"
				>
					Elige tu plan
				</h2>
				<p class="text-gray-400 text-center mb-6 max-w-2xl mx-auto">
					Escala tus ventas en automático con el plan que mejor se
					adapte a ti.
					<br /><span class="text-xs text-gray-500 mt-2 block"
						>* Compras fuera de España pueden estar sujetas a
						comisiones por cambio de divisa o transacciones
						internacionales.</span
					>
				</p>

				<div class="flex justify-center mb-12">
					<div
						class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-green/10 border border-brand-green/30 text-brand-green text-sm font-semibold shadow-[0_0_15px_rgba(34,197,94,0.15)]"
					>
						<span>🎁</span> ¡Tienes 1 día de prueba gratis sin compromiso!
					</div>
				</div>

				<div
					class="grid md:grid-cols-3 gap-8 items-stretch relative z-10"
				>
					<!-- Plan 1 Mes -->
					<div
						class="bg-gray-900 border border-gray-800 rounded-3xl p-8 flex flex-col relative hover:border-brand-green/30 hover:shadow-[0_0_20px_rgba(34,197,94,0.1)] transition duration-500 overflow-hidden group"
					>
						<div
							class="absolute inset-0 bg-gradient-to-b from-brand-green/5 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"
						>
						</div>
						<div class="relative z-10 flex flex-col h-full">
							<h3 class="text-xl font-bold text-white mb-2">
								1 Mes
							</h3>
							<p class="text-gray-400 mb-6 text-sm">
								Perfecto para probar la herramienta en una
								campaña puntual.
							</p>
							<div class="flex items-end gap-1 mb-8">
								<span class="text-5xl font-black text-white"
									>10,99€</span
								>
								<span class="text-gray-400 mb-1 font-medium"
									>/mes</span
								>
							</div>
							<ul class="text-left space-y-4 mb-8 flex-1">
								<li
									class="flex items-start text-gray-300 text-sm"
								>
									<span
										class="text-brand-green mr-2 mt-0.5 font-bold"
										>✓</span
									> Software Completo
								</li>
								<li
									class="flex items-start text-gray-300 text-sm"
								>
									<span
										class="text-brand-green mr-2 mt-0.5 font-bold"
										>✓</span
									> Scraper + Detector Tecnología
								</li>
								<li
									class="flex items-start text-gray-300 text-sm"
								>
									<span
										class="text-brand-green mr-2 mt-0.5 font-bold"
										>✓</span
									> Exportación a CSV / Excel
								</li>
								<li
									class="flex items-start text-gray-300 text-sm"
								>
									<span
										class="text-brand-green mr-2 mt-0.5 font-bold"
										>✓</span
									> Guía de Instalación
								</li>
							</ul>
							<button
								onclick="document.getElementById('purchase-modal').classList.remove('hidden')"
								class="w-full bg-gray-800 hover:bg-gray-700 text-white font-bold py-3.5 rounded-xl transition mt-auto border border-gray-700 hover:border-brand-green/50"
							>
								Elegir Plan
							</button>
						</div>
					</div>

					<!-- Plan 3 Meses -->
					<div
						class="bg-gradient-to-b from-gray-800 to-gray-900 rounded-3xl p-1 bg-gradient-to-br from-brand-green via-brand-cyan to-brand-green relative transform md:-translate-y-4 shadow-[0_0_30px_rgba(34,197,94,0.2)] hover:shadow-[0_0_40px_rgba(34,197,94,0.4)] transition duration-500"
					>
						<div
							class="absolute inset-0 bg-brand-green opacity-20 blur-xl rounded-full pointer-events-none"
						>
						</div>
						<div
							class="bg-brand-dark rounded-[23px] p-8 h-full flex flex-col relative overflow-hidden z-10"
						>
							<div
								class="absolute top-0 right-0 bg-brand-green text-xs font-black px-4 py-1.5 rounded-bl-xl rounded-tr-[22px] text-black uppercase tracking-wider shadow-md"
							>
								Más Popular
							</div>
							<h3
								class="text-2xl font-black text-white mb-2 flex items-center gap-2"
							>
								3 Meses <span class="text-xl">🚀</span>
							</h3>
							<p class="text-gray-400 mb-6 text-sm">
								Ahorra y domina tu nicho durante un trimestre
								entero.
							</p>
